# ============================================
# VOOM Car Sharing Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ---- Server ----
NODE_ENV=development
PORT=5000
SESSION_SECRET=your-session-secret-here-change-in-production
PASSWORD_PEPPER=optional-additional-password-security

# ---- Database (PostgreSQL for production) ----
DATABASE_URL=postgresql://user:password@localhost:5432/voom

# ---- Google OAuth2 ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- MTN MoMo ----
MOMO_API_KEY=your-momo-api-key
MOMO_API_SECRET=your-momo-api-secret
MOMO_SUBSCRIPTION_KEY=your-subscription-key
MOMO_ENVIRONMENT=sandbox
MOMO_CALLBACK_URL=https://your-domain.com/api/payments/momo/callback

# ---- Frontend URL (for CORS in production) ----
FRONTEND_URL=https://your-frontend-domain.com

# ---- Supabase (optional - if using Supabase) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Analytics (optional) ----
VITE_POSTHOG_API_KEY=your-posthog-key
VITE_LOGROCKET_APP_ID=your-logrocket-app-id
